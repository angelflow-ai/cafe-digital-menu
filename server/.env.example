PORT=4000
CLIENT_ORIGIN=http://localhost:5173
MONGODB_URI=
SESSION_SECRET=change-this-secret

# Owner / admin account used for the Owner login and setup flow.
# Set this to your real owner email before starting the server.
ADMIN_EMAIL=owner@theinfusionsaga.com
ADMIN_PASSWORD=infusion-owner
OWNER_EMAIL=owner@theinfusionsaga.com

# Optional alias for the owner email list if you want to override the default owner account.
# OWNER_EMAILS=owner@yourdomain.com

# Biller account used for the Biller login and setup flow.
# Set this to your real biller email before starting the server.
BILLER_EMAIL=biller@theinfusionsaga.com
BILLER_PASSWORD=infusion-biller

# Optional alias for the biller email list if you want to override the default biller account.
# BILLER_EMAILS=biller@yourdomain.com

# Production SMTP (required for auth email delivery)
SMTP_HOST=mail.theinfusionsaga.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=owner@theinfusionsaga.com
SMTP_PASS=
EMAIL_FROM=owner@theinfusionsaga.com

